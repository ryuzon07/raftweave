# ============================================================
# RaftWeave Environment Variables
# Copy to .env and fill in values: cp .env.example .env
# ============================================================

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=raftweave
POSTGRES_USER=raftweave
POSTGRES_PASSWORD=raftweave_secret
POSTGRES_SSL_MODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret

# Raft Cluster
RAFT_NODE_ID=1
RAFT_BIND_ADDR=0.0.0.0:7001
RAFT_PEERS=localhost:7001,localhost:7002,localhost:7003
RAFT_DATA_DIR=./data/raft
RAFT_ELECTION_TIMEOUT_MS=1500
RAFT_HEARTBEAT_INTERVAL_MS=500

# Build Pipeline
REGISTRY_URL=localhost:5000
REGISTRY_USERNAME=
REGISTRY_PASSWORD=
KANIKO_CACHE_REPO=

# Cloud Credentials (AWS)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1

# Cloud Credentials (Azure)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# Cloud Credentials (GCP)
GOOGLE_APPLICATION_CREDENTIALS=
GCP_PROJECT_ID=

# OAuth2
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URL=http://localhost:4200/auth/callback
SESSION_SECRET=change-me-to-a-random-secret

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=raftweave
OTEL_ENVIRONMENT=development

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8001
LOG_LEVEL=debug
